{
  "name": "sentinel-market",
  "private": true,
  "version": "0.1.0",
  "description": "Sentinel Prime tech marketplace storefront built with Netlify, Next.js, Supabase, and Stripe.",
  "packageManager": "pnpm@9.12.3",
  "scripts": {
    "dev": "corepack pnpm --filter @sentinel-market/storefront dev",
    "dev:storefront": "corepack pnpm --filter @sentinel-market/storefront dev",
    "build": "corepack pnpm --filter @sentinel-market/storefront build",
    "lint": "corepack pnpm --filter @sentinel-market/storefront lint",
    "typecheck": "corepack pnpm --filter @sentinel-market/storefront typecheck"
  },
  "engines": {
    "node": ">=20 <25",
    "pnpm": ">=9"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.6",
    "stripe": "^17.4.0"
  },
  "devDependencies": {
    "@netlify/plugin-nextjs": "^5.8.1"
  }
}
